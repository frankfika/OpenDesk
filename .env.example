# Copy this file to `.env` and fill in real values before running the
# end-to-end tests:
#
#   cp .env.example .env
#   npm run test:e2e
#
# Variables are intentionally documented; no secrets are shipped in the
# repository, and the e2e suite skips any test that requires one.

# Required for the e2e tests that seed a live model provider. Without this
# variable, `e2e/app.spec.ts` will skip the agent-mode / ensemble-mode /
# file-attachment cases. The "electron app launches" test does not need it.
DEEPSEEK_API_KEY=

# Optional. Etherscan v2 multichain API key (https://etherscan.io/apis). Used by
# the Web3 Workbench (renderer) for tx history, token lists and approvals across
# all chains. Without it those calls are heavily rate-limited and may return
# empty. Exposed to the renderer, so it must be prefixed with VITE_.
VITE_ETHERSCAN_API_KEY=

# Optional. 0x aggregator API key (https://dashboard.0x.org). Enables the
# web3_getSwapCalldata tool to return executable swap calldata. Without it the
# tool returns a non-executable route plan only. Read in the main process.
ZEROX_API_KEY=
