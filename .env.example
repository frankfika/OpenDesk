# Copy this file to `.env` and fill in real values before running the
# end-to-end tests:
#
#   cp .env.example .env
#   npm run test:e2e
#
# Variables are intentionally documented; no secrets are shipped in the
# repository, and the e2e suite skips any test that requires one.

# Required for the e2e tests that seed a live model provider. Without this
# variable, `e2e/app.spec.ts` will skip the agent-mode / ensemble-mode /
# file-attachment cases. The "electron app launches" test does not need it.
DEEPSEEK_API_KEY=
